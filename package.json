const express = require('express');
const http = require('http');
const WebSocket = require('ws');
const path = require('path');

const app = express();
const server = http.createServer(app);
const wss = new WebSocket.Server({ server });

// Хранилище всех подключенных клиентов
const clients = new Set();

// Раздаём статические файлы из папки public
app.use(express.static(path.join(__dirname, 'public')));

// Для всех остальных маршрутов отдаём index.html
app.get('*', (req, res) => {
    res.sendFile(path.join(__dirname, 'public', 'index.html'));
});

// Обработка WebSocket соединений
wss.on('connection', (ws) => {
    console.log('🔌 Новый клиент подключился');
    console.log('📊 Всего клиентов онлайн:', clients.size + 1);
    
    // Добавляем нового клиента в Set
    clients.add(ws);

    // Обработка входящих сообщений
    ws.on('message', (message) => {
        const messageStr = message.toString();
        console.log('📨 Получено сообщение:', messageStr);
        console.log('📤 Отправляем всем клиентам...');
        
        // Отправляем сообщение ВСЕМ подключенным клиентам
        clients.forEach((client) => {
            if (client.readyState === WebSocket.OPEN) {
                client.send(messageStr);
            }
        });
        
        console.log('✅ Сообщение разослано всем');
    });

    // Обработка отключения клиента
    ws.on('close', () => {
        console.log('❌ Клиент отключился');
        clients.delete(ws);
        console.log('📊 Осталось клиентов:', clients.size);
    });
    
    // Обработка ошибок
    ws.on('error', (error) => {
        console.error('⚠️ Ошибка WebSocket:', error);
    });
});

// Запуск сервера
const PORT = process.env.PORT || 3000;
server.listen(PORT, () => {
    console.log(`✅ Сервер успешно запущен!`);
    console.log(`🌐 Локальный адрес: http://localhost:${PORT}`);
    console.log(`🌍 Внешний адрес: https://messenger-jlmn.onrender.com`);
    console.log(`💬 WebSocket сервер готов к работе`);
});